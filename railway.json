{
  "$schema": "https://railway.app/configs/railway-v1.schema.json",
  "services": {
    "backend": {
      "name": "smarttutor-backend",
      "rootDirectory": "./backend",
      "build": {
        "builder": "DOCKER",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleepApplication": false
      }
    },
    "frontend": {
      "name": "smarttutor-frontend",
      "rootDirectory": "./frontend",
      "build": {
        "builder": "DOCKER",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleepApplication": false
      }
    }
  }
}
